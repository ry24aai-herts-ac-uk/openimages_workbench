# =============================================================================
# Rust / Cargo (backend)
# =============================================================================

# Compiled files and executables
debug/
target/

# Backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows debugging information
*.pdb

# Generated by cargo mutants (mutation testing data)
**/mutants.out*/

# =============================================================================
# Tauri
# =============================================================================

# Tauri build output (also covered by target/ above for src-tauri)
src-tauri/target/
src-tauri/WixTools/

# =============================================================================
# SvelteKit / Node (frontend)
# =============================================================================

# Node dependencies
node_modules/

# SvelteKit generated files
.svelte-kit/

# Build output
build/
dist/

# Vite timestamp files
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Environment variable files (keep the example template)
.env
.env.*
!.env.example

# =============================================================================
# General / OS
# =============================================================================

# macOS
.DS_Store

# Windows
Thumbs.db

# Editor / IDE directories
.vscode/
.idea/

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Package manager lock files (keep one; uncomment to ignore)
# package-lock.json
# yarn.lock
